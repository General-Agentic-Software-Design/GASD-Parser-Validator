CONTEXT: "Test System"
TARGET: "Python3"

TYPE User:
    id: Integer
    name: String
    email: Optional<String>

COMPONENT UserAuth:
    PATTERN: "Service"
    INTERFACE:
        login(u: User) -> Boolean
        logout() -> Boolean

FLOW user_login_flow(u: User) -> Boolean:
    1. VALIDATE "user credentials"
    2. ACHIEVE "open session"
    3. RETURN true

STRATEGY AuthStrategy:
    ALGORITHM: "OAuth2"
    INPUT: u: User
    OUTPUT: Boolean

DECISION "Auth Type":
    CHOSEN: "JWT"
    AFFECTS: ["UserAuth"]

CONSTRAINT: "Users must be unique"
INVARIANT: "Session must be active"

QUESTION: "Continue login?"
    BLOCKING: true

APPROVE "User Registration":
    STATUS: APPROVED
    BY: "Admin"
    DATE: "2026-03-05"

TODO: "Implement MFA"
REVIEW: "Security check"
