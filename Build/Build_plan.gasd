/* 
   --- Build Plan: GASD Parser & Validator ---
   Expert implementation of building and testing the official GASD parser.
   Strictly follows GASD 1.1.0 normative specification:
  https://github.com/General-Agentic-Software-Design/General-Agentic-Software-Design-Language/blob/main/GASD-1.1/GASD_Specification.md
  Strictly follows the user story in Requirements/User_story.md
*/

CONTEXT: "Compiler / Language Tooling"
TARGET: "ANTLR4", "Python3"
TRACE: "EPIC-PARSER-001", "US-PARSER-001", "US-PARSER-002", "US-PARSER-003", "US-PARSER-004", "US-PARSER-005", "US-PARSER-006"

// ===================================================================
// PHASE 1 — Design (Output: Design/ folder)
// Generate design-level GASD specifications for each component.
// ===================================================================

/// Requirement: Always read Requirements/User_story.md first
/// to ensure 100% coverage and traceability.
FLOW phase1_generate_designs():
    1. ACHIEVE "Read Requirements/User_story.md"
    2. VALIDATE "All #US, #AC, #AT, #RT IDs are extracted"
    3. ACHIEVE "Generate Design/grammar_design.gasd" @trace #US-PARSER-001
    4. ACHIEVE "Generate Design/parse_tree_design.gasd" @trace #US-PARSER-002
    5. ACHIEVE "Generate Design/ast_design.gasd" @trace #US-PARSER-003
    6. ACHIEVE "Generate Design/semantic_validation_design.gasd" @trace #US-PARSER-004
    7. ACHIEVE "Generate Design/error_reporting_design.gasd" @trace #US-PARSER-005
    8. ACHIEVE "Generate Design/cli_design.gasd" @trace #US-PARSER-006
    9. VALIDATE "All AC IDs are traced in design files"

// ===================================================================
// PHASE 2 — Implementation (Output: Impl/ folder)
// Generate production code from Phase 1 designs.
// ===================================================================

FLOW phase2_generate_implementation():
    1. ACHIEVE "Implement Impl/grammar/gasd.g4 from Design/grammar_design.gasd" @trace #US-PARSER-001
    2. EXECUTE "antlr4 -Dlanguage=Python3 -visitor Impl/grammar/gasd.g4 -o Impl/parser/generated"
    3. VALIDATE "Grammar compiles successfully" @trace #AC-PARSER-001-02
    4. ACHIEVE "Implement Impl/parser/ from Design/parse_tree_design.gasd" @trace #US-PARSER-002
    5. ACHIEVE "Implement Impl/ast/ from Design/ast_design.gasd" @trace #US-PARSER-003
    6. ACHIEVE "Implement Impl/validation/ from Design/semantic_validation_design.gasd" @trace #US-PARSER-004
    7. ACHIEVE "Implement Impl/errors/ from Design/error_reporting_design.gasd" @trace #US-PARSER-005

// ===================================================================
// PHASE 3 — Testing (Output: Impl/tests/ folder)
// Generate all acceptance and regression tests, then run to pass.
// ===================================================================

FLOW phase3_generate_tests():
    // Acceptance Tests
    1. ACHIEVE "Generate Impl/tests/acceptance/test_grammar.py" @trace #AT-PARSER-001-01, #AT-PARSER-001-02, #AT-PARSER-001-03, #AT-PARSER-001-04
    2. ACHIEVE "Generate Impl/tests/acceptance/test_parse_tree.py" @trace #AT-PARSER-002-01, #AT-PARSER-002-02, #AT-PARSER-002-03
    3. ACHIEVE "Generate Impl/tests/acceptance/test_ast.py" @trace #AT-PARSER-003-01, #AT-PARSER-003-02, #AT-PARSER-003-03
    4. ACHIEVE "Generate Impl/tests/acceptance/test_semantic.py" @trace #AT-PARSER-004-01, #AT-PARSER-004-02, #AT-PARSER-004-03
    5. ACHIEVE "Generate Impl/tests/acceptance/test_errors.py" @trace #AT-PARSER-005-01, #AT-PARSER-005-02
    6. ACHIEVE "Generate Impl/tests/acceptance/test_cli_runner.py" @trace #AT-PARSER-006-01, #AC-PARSER-006-02, #AC-PARSER-006-03
    // Regression Tests
    7. ACHIEVE "Generate Impl/tests/regression/test_grammar.py" @trace #RT-PARSER-001-01, #RT-PARSER-001-02, #RT-PARSER-001-03
    8. ACHIEVE "Generate Impl/tests/regression/test_parse_tree.py" @trace #RT-PARSER-002-01, #RT-PARSER-002-02
    9. ACHIEVE "Generate Impl/tests/regression/test_ast.py" @trace #RT-PARSER-003-01, #RT-PARSER-003-02
    10. ACHIEVE "Generate Impl/tests/regression/test_semantic.py" @trace #RT-PARSER-004-01, #RT-PARSER-004-02
    11. ACHIEVE "Generate Impl/tests/regression/test_errors.py" @trace #RT-PARSER-005-01
    12. ACHIEVE "Include CLI regression in RT-PARSER-006-01" @trace #RT-PARSER-006-01

/// Quality Gate: All tests must pass before delivery.
FLOW run_to_pass():
    1. EXECUTE "pytest Impl/tests"
    2. EXECUTE "gasd-parser ./Ref-Specs"
    3. ENSURE "Dont make any changes to the gasd files in Ref-Specs folder"
    4. ENSURE "Fixing implementation till zero warnings or errors from 'gasd-parser ./Ref-Specs'"
    5. ENSURE "Fixing implementation till All tests pass"
        OTHERWISE THROW "Build Failure: Quality Gate Failed"

// ===================================================================
// PHASE 4 — Packaging (Output: Build/Installation/ folder)
// Package the GASD parser as a standalone installable application.
// ===================================================================

FLOW phase4_package_standalone():
    1. ACHIEVE "Create Build/Installation/setup.py with package metadata"
    2. ACHIEVE "Create Build/Installation/pyproject.toml with build system config"
    3. ACHIEVE "Create Build/Installation/gasd_parser/ package directory"
    4. ACHIEVE "Copy Impl/ source into Build/Installation/gasd_parser/"
    5. ACHIEVE "Create Build/Installation/gasd_parser/__main__.py as CLI entry point"
    6. ACHIEVE "Create Build/Installation/gasd_parser/cli.py with argument parsing"
    7. ACHIEVE "Create Build/Installation/README.md with usage instructions"
    8. VALIDATE "pip install -e Build/Installation succeeds"
    9. VALIDATE "gasd-parser --help shows CLI usage"
    10. VALIDATE "gasd-parser Specs/valid_sample.gasd exits 0"
    11. VALIDATE "gasd-parser Specs/invalid_duplicates.gasd exits non-zero"
    12. VALIDATE "gasd-parser parses multiple files and directories recursively" @trace #AC-PARSER-006-01, #AC-PARSER-006-02
