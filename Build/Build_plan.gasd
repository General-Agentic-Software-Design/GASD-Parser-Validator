/*
   --- Build Plan: GASD Parser & Validator ---
   Expert implementation of building and testing the official GASD parser.
   Strictly follows GASD 1.1.0 normative specification:
    - Specs/GASD_Specification-1.1.md
    - Specs/gasd-1.1.0.gasd
    - Requirements/ver-1.2/GASD Semantic AST.md
    - Requirements/ver-1.2/Built-in-types-support.md
    Strictly follows the user story in Requirements/*
*/

CONTEXT: "Compiler / Language Tooling"
TARGET: "ANTLR4", "Python3"
TRACE: "EPIC-PARSER-001", "US-PARSER-001", "US-PARSER-002", "US-PARSER-003", "US-PARSER-004", "US-PARSER-005", "US-PARSER-006", "US-PARSER-007", "US-PARSER-008", "EPIC-SEMAST-001", "US-SEMAST-001", "US-SEMAST-002", "US-SEMAST-003", "US-SEMAST-004", "US-SEMAST-005", "US-SEMAST-006", "US-SEMAST-007", "US-SEMAST-008", "US-SEMAST-009", "US-SEMAST-010", "US-SEMAST-011", "US-SEMAST-012", "US-SEMAST-013", "US-SEMAST-014", "US-SEMAST-015", "US-SEMAST-016", "US-SEMAST-017", "US-SEMAST-018", "EPIC-X-SEMAST-001", "US-X-SEMAST-001", "US-X-SEMAST-002", "US-X-SEMAST-003", "US-X-SEMAST-004", "US-X-SEMAST-005", "US-X-SEMAST-006", "US-X-SEMAST-007", "US-X-SEMAST-008", "US-X-SEMAST-009", "US-X-SEMAST-010", "US-X-SEMAST-011", "US-X-SEMAST-012"

// ===================================================================
// PHASE 1 — Design (Output: Design/ folder)
// Generate design-level GASD specifications for each component.
// ===================================================================

/// Requirement: Always read Requirements/ver-1.0/User_story.md first
/// to ensure 100% coverage and traceability.
FLOW phase1_generate_designs():
    1. ACHIEVE "Read Requirements/ver-1.0/User_story.md"
    2. ENSURE "All #US, #AC, #AT, #RT IDs are extracted"
    3. ACHIEVE "Generate Design/grammar_design.gasd" @trace #US-PARSER-001
    4. ACHIEVE "Generate Design/parse_tree_design.gasd" @trace #US-PARSER-002
    5. ACHIEVE "Generate Design/ast_design.gasd" @trace #US-PARSER-003
    6. ACHIEVE "Generate Design/semantic_validation_design.gasd" @trace #US-PARSER-004
    7. ACHIEVE "Generate Design/error_reporting_design.gasd" @trace #US-PARSER-005
    8. ACHIEVE "Generate Design/cli_design.gasd" @trace #US-PARSER-006
    9. ACHIEVE "Update Design/ast_design.gasd & Design/cli_design.gasd for JSON extraction" @trace #US-PARSER-007
    10. ACHIEVE "Update Design/grammar_design.gasd & Design/ast_design.gasd for VALIDATE AS TYPE binding" @trace #US-PARSER-008
    11. ENSURE "All AC IDs are traced in design files"

// ===================================================================
// PHASE 2 — Validation Specifications (Output: Validation/ folder)
// Generate explicit, comprehensive GASD test cases strictly based on the Design/ folder.
// ===================================================================

FLOW phase2_generate_validation_specs():
    1. ACHIEVE "Generate Validation/grammar_tests.gasd from Design/grammar_design.gasd"
    2. ACHIEVE "Generate Validation/parse_tree_tests.gasd from Design/parse_tree_design.gasd"
    3. ACHIEVE "Generate Validation/ast_tests.gasd from Design/ast_design.gasd"
    4. ACHIEVE "Generate Validation/semantic_validation_tests.gasd from Design/semantic_validation_design.gasd"
    5. ACHIEVE "Generate Validation/error_reporting_tests.gasd from Design/error_reporting_design.gasd"
    6. ACHIEVE "Generate Validation/cli_tests.gasd from Design/cli_tests.gasd"
    7. ENSURE "Validation specs cover all constraints and type definitions present in the Design folder"


// ===================================================================
// PHASE 3 — Testing (Output: Impl/tests/ folder)
// Generate all acceptance and regression tests, then run to pass.
// ===================================================================

FLOW phase3_generate_tests():
    /// Requirement: Consult ONLY Requirements/ and Design/ folders.
    /// Do NOT use Impl/ (implementation) as a reference during test generation.
    1. ACHIEVE "Review Requirements/, Validation/ and Design/ for testing scope"
    // Acceptance Tests
    2. ACHIEVE "Generate Impl/tests/acceptance/test_grammar.py" @trace #AT-PARSER-001-01, #AT-PARSER-001-02, #AT-PARSER-001-03, #AT-PARSER-001-04
    3. ACHIEVE "Generate Impl/tests/acceptance/test_parse_tree.py" @trace #AT-PARSER-002-01, #AT-PARSER-002-02, #AT-PARSER-002-03
    4. ACHIEVE "Generate Impl/tests/acceptance/test_ast.py" @trace #AT-PARSER-003-01, #AT-PARSER-003-02, #AT-PARSER-003-03
    5. ACHIEVE "Generate Impl/tests/acceptance/test_semantic.py" @trace #AT-PARSER-004-01, #AT-PARSER-004-02, #AT-PARSER-004-03
    6. ACHIEVE "Generate Impl/tests/acceptance/test_errors.py" @trace #AT-PARSER-005-01, #AT-PARSER-005-02
    7. ACHIEVE "Generate Impl/tests/acceptance/test_cli_runner.py" @trace #AT-PARSER-006-01, #AC-PARSER-006-02, #AC-PARSER-006-03
    8. ACHIEVE "Generate Impl/tests/acceptance/test_ast_extraction.py covering all AT-PARSER-007-0* tests" @trace #AT-PARSER-007-01, #AT-PARSER-007-02, #AT-PARSER-007-03, #AT-PARSER-007-04, #AT-PARSER-007-05, #AT-PARSER-007-06, #AT-PARSER-007-07, #AT-PARSER-007-08
    9. ACHIEVE "Generate Impl/tests/acceptance/test_explicit_binding.py covering AT-VALIDATE-001, AT-VALIDATE-002, AT-VALIDATE-003, NT-VALIDATE-001, NT-VALIDATE-002" @trace #US-PARSER-008
    // Regression Tests
    10. ACHIEVE "Generate Impl/tests/regression/test_grammar.py" @trace #RT-PARSER-001-01, #RT-PARSER-001-02, #RT-PARSER-001-03
    11. ACHIEVE "Generate Impl/tests/regression/test_parse_tree.py" @trace #RT-PARSER-002-01, #RT-PARSER-002-02
    12. ACHIEVE "Generate Impl/tests/regression/test_ast.py" @trace #RT-PARSER-003-01, #RT-PARSER-003-02
    13. ACHIEVE "Generate Impl/tests/regression/test_semantic.py" @trace #RT-PARSER-004-01, #RT-PARSER-004-02
    14. ACHIEVE "Generate Impl/tests/regression/test_errors.py" @trace #RT-PARSER-005-01
    15. ACHIEVE "Include CLI regression in RT-PARSER-006-01" @trace #RT-PARSER-006-01
    16. ACHIEVE "Add exhaustive AST extraction regression tests in Impl/tests/regression/test_ast_regression.py" @trace #RT-PARSER-007-01, #RT-PARSER-007-02, #RT-PARSER-007-03, #RT-PARSER-007-04, #RT-PARSER-007-05, #RT-PARSER-007-06, #RT-PARSER-007-07
    17. ACHIEVE "Add exhaustive VALIDATE AS TYPE binding regression tests in Impl/tests/regression/test_binding_regression.py" @trace #RT-VALIDATE-001, #RT-VALIDATE-002
    18. ENSURE "100% Traceability and Coverage for all AC-PARSER-007-*, AT-PARSER-007-*, and RT-PARSER-007-*"
    // Negative Tests
    26. ACHIEVE "Add exhaustive negative testing suite covering all spec constraints (V001-V014, S001-S002)" @trace #US-PARSER-005, #US-PARSER-008
    27. ACHIEVE "Generate Specs/exhaustive_negative_examples.gasd as normative negative reference"
    // Design Validation Tests
    19. ACHIEVE "Generate Impl/tests/design_validation/grammar_tests.py from Validation/grammar_tests.gasd"
    20. ACHIEVE "Generate Impl/tests/design_validation/parse_tree_tests.py from Validation/parse_tree_tests.gasd"
    21. ACHIEVE "Generate Impl/tests/design_validation/ast_tests.py from Validation/ast_tests.gasd"
    22. ACHIEVE "Generate Impl/tests/design_validation/semantic_validation_tests.py from Validation/semantic_validation_tests.gasd"
    23. ACHIEVE "Generate Impl/tests/design_validation/error_reporting_tests.py from Validation/error_reporting_tests.gasd"
    24. ACHIEVE "Generate Impl/tests/design_validation/cli_tests.py from Validation/cli_tests.gasd"
    25. ENSURE "100% Traceability and Coverage for all Design Validation Tests"


// ===================================================================
// PHASE 4 — Implementation (Output: Impl/ folder)
// Generate production code from Phase 1 designs.
// ===================================================================

FLOW phase4_generate_implementation():
    1. ACHIEVE "Implement Impl/grammar/gasd.g4 from Design/grammar_design.gasd" @trace #US-PARSER-001
    2. ACHIEVE "antlr4 -Dlanguage=Python3 -visitor Impl/grammar/gasd.g4 -o Impl/parser/generated"
    3. ENSURE "Grammar compiles successfully" @trace #AC-PARSER-001-02
    4. ACHIEVE "Implement Impl/parser/ from Design/parse_tree_design.gasd" @trace #US-PARSER-002
    5. ACHIEVE "Implement Impl/ast/ from Design/ast_design.gasd" @trace #US-PARSER-003
    6. ACHIEVE "Implement Impl/validation/ from Design/semantic_validation_design.gasd" @trace #US-PARSER-004
    7. ACHIEVE "Implement Impl/errors/ from Design/error_reporting_design.gasd" @trace #US-PARSER-005
    8. ACHIEVE "Implement AST JSON Export in Impl/ast/ & Impl/cli/" @trace #US-PARSER-007
    9. ACHIEVE "Implement Mandatory VALIDATE AS TYPE Binding in Impl/parser/ & Impl/validation/" @trace #US-PARSER-008

/// Quality Gate: All tests must pass before delivery.
FLOW run_to_pass():
    1. ACHIEVE "pytest Impl/tests including acceptance, regression and design validation tests"
    2. ENSURE "Fixing implementation till All tests pass"
        OTHERWISE THROW "Build Failure: Quality Gate Failed"

// ===================================================================
// PHASE 5 — Semantic AST Preparation & Built-in Types (Output: Impl/semantic/SymbolTable.py)
// Foundation for the Semantic Type System.
// Strictly follows: Requirements/ver-1.2/Built-in-types-support.md
// ===================================================================

FLOW phase5_semantic_ast_prep():
    /// Requirement: Always read Requirements/ver-1.2/Built-in-types-support.md
    /// to ensure 100% coverage and traceability for US-SEMAST-019 and US-SEMAST-020.
    1. ACHIEVE "Read Requirements/ver-1.2/Built-in-types-support.md"
    2. ENSURE "All #US-SEMAST-019/020, #AC-SEMAST, #AT-SEMAST, #NT-SEMAST IDs are extracted"

    // --- Implementation ---
    3. ACHIEVE "Update Impl/semantic/SymbolTable.py to pre-register 14 built-in types" @trace #US-SEMAST-019, #AC-SEMAST-019-01
    4. ACHIEVE "Update Impl/validation/passes/ReferenceResolutionPass.py to recognize built-in types" @trace #US-SEMAST-019, #AC-SEMAST-019-02
    5. ACHIEVE "Ensure VALIDATE AS TYPE bindings resolve to built-in types" @trace #US-SEMAST-019, #AC-SEMAST-019-06

    // --- Backward Compatibility Gate (US-SEMAST-020) ---
    6. ACHIEVE "Run full test suite (pytest Impl/tests/)" @trace #AT-SEMAST-020-01
    7. ENSURE "Legacy examples like validate_simple.gasd pass without V008 warnings" @trace #AT-SEMAST-020-02
    8. ENSURE "All existing syntactic and semantic features remain functional" @trace #AC-SEMAST-020-03

// ===================================================================
// PHASE 6 — Semantic AST Design (Output: Design/ folder)
// Generate design-level GASD specifications for each Semantic AST component.
// Strictly follows: Requirements/ver-1.2/GASD Semantic AST.md & Requirements/ver-1.2/Built-in-types-support.md
// ===================================================================

/// Requirement: Always read Requirements/ver-1.2/GASD Semantic AST.md and Requirements/ver-1.2/Built-in-types-support.md
/// to ensure 100% coverage and traceability for all user stories.
FLOW phase6_semantic_ast_design():
    1. ACHIEVE "Read Requirements/ver-1.2/GASD Semantic AST.md, Requirements/ver-1.2/Built-in-types-support.md and Requirements/ver-1.3/Cross-File Semantic AST Validation.md"
    2. ENSURE "All #US-SEMAST, #US-X-SEMAST, #AC-SEMAST, #AC-X-SEMAST, #AT-SEMAST, #AT-X-SEMAST, #RT-SEMAST, #RT-X-SEMAST IDs are extracted"
    // Core Semantic Model Designs
    3. ACHIEVE "Generate Design/semantic_ast_model_design.gasd" @trace #US-SEMAST-001, #US-X-SEMAST-001
    4. ACHIEVE "Generate Design/symbol_resolution_design.gasd" @trace #US-SEMAST-002, #US-X-SEMAST-003
    5. ACHIEVE "Generate Design/type_contract_binding_design.gasd" @trace #US-SEMAST-003, #US-X-SEMAST-004, #US-X-SEMAST-007
    6. ACHIEVE "Generate Design/annotation_handling_design.gasd" @trace #US-SEMAST-004
    7. ACHIEVE "Generate Design/architecture_deps_design.gasd" @trace #US-SEMAST-005, #US-X-SEMAST-005
    // FLOW & Strategy & Decision Designs
    8. ACHIEVE "Generate Design/flow_semantic_analysis_design.gasd" @trace #US-SEMAST-006, #US-X-SEMAST-006
    9. ACHIEVE "Generate Design/strategy_resolution_design.gasd" @trace #US-SEMAST-007
    10. ACHIEVE "Generate Design/decision_resolution_design.gasd" @trace #US-SEMAST-008, #US-X-SEMAST-008
    // Infrastructure Designs
    11. ACHIEVE "Generate Design/namespace_import_design.gasd" @trace #US-SEMAST-009, #US-X-SEMAST-002
    12. ACHIEVE "Generate Design/semantic_hashing_design.gasd" @trace #US-SEMAST-010, #US-X-SEMAST-011
    13. ACHIEVE "Generate Design/cicd_determinism_design.gasd" @trace #US-SEMAST-011
    14. ACHIEVE "Generate Design/semantic_error_reporting_design.gasd" @trace #US-SEMAST-012, #US-X-SEMAST-010
    // Spec-Specific Construct Designs
    15. ACHIEVE "Generate Design/context_directive_design.gasd" @trace #US-SEMAST-013
    16. ACHIEVE "Generate Design/human_in_loop_design.gasd" @trace #US-SEMAST-014
    17. ACHIEVE "Generate Design/resource_block_design.gasd" @trace #US-SEMAST-015
    // New Global Consistency Designs
    18. ACHIEVE "Generate Design/global_invariants_design.gasd" @trace #US-X-SEMAST-009
    // CLI & Compatibility Designs
    19. ACHIEVE "Update Design/cli_design.gasd for --ast-sem option" @trace #US-SEMAST-016
    20. ACHIEVE "Generate Design/backward_compatibility_design.gasd" @trace #US-SEMAST-017, #US-SEMAST-020
    21. ACHIEVE "Update Design/cli_design.gasd for --ast-output/--ast-combine reuse with --ast-sem" @trace #US-SEMAST-018
    22. ACHIEVE "Generate Design/builtin_types_design.gasd" @trace #US-SEMAST-019
    23. ACHIEVE "Generate Design/cross_file_test_matrix.gasd" @trace #US-X-SEMAST-012
    24. ENSURE "All AC-SEMAST and AC-X-SEMAST IDs are traced in design files"

// ===================================================================
// PHASE 7 — Semantic AST Validation Specs (Output: Validation/ folder)
// Generate comprehensive GASD test case specs for Semantic AST.
// Strictly follows: Requirements/ver-1.2/GASD Semantic AST.md & Requirements/ver-1.2/Built-in-types-support.md
// ===================================================================

FLOW phase7_semantic_ast_validation_specs():
    /// Requirement: Consult Requirements/ver-1.2/GASD Semantic AST.md, Requirements/ver-1.2/Built-in-types-support.md and Requirements/ver-1.3/Cross-File Semantic AST Validation.md.
    1. ACHIEVE "Read Requirements/ver-1.3/Cross-File Semantic AST Validation.md"
    2. ACHIEVE "Generate Validation/semantic_ast_model_tests.gasd from Design/semantic_ast_model_design.gasd"
    3. ACHIEVE "Generate Validation/symbol_resolution_tests.gasd from Design/symbol_resolution_design.gasd"
    4. ACHIEVE "Generate Validation/type_contract_binding_tests.gasd from Design/type_contract_binding_design.gasd"
    5. ACHIEVE "Generate Validation/annotation_handling_tests.gasd from Design/annotation_handling_design.gasd"
    6. ACHIEVE "Generate Validation/architecture_deps_tests.gasd from Design/architecture_deps_design.gasd"
    7. ACHIEVE "Generate Validation/flow_semantic_analysis_tests.gasd from Design/flow_semantic_analysis_design.gasd"
    8. ACHIEVE "Generate Validation/strategy_resolution_tests.gasd from Design/strategy_resolution_design.gasd"
    9. ACHIEVE "Generate Validation/decision_resolution_tests.gasd from Design/decision_resolution_design.gasd"
    10. ACHIEVE "Generate Validation/namespace_import_tests.gasd from Design/namespace_import_design.gasd"
    11. ACHIEVE "Generate Validation/semantic_hashing_tests.gasd from Design/semantic_hashing_design.gasd"
    12. ACHIEVE "Generate Validation/context_directive_tests.gasd from Design/context_directive_design.gasd"
    13. ACHIEVE "Generate Validation/human_in_loop_tests.gasd from Design/human_in_loop_design.gasd"
    14. ACHIEVE "Generate Validation/resource_block_tests.gasd from Design/resource_block_design.gasd"
    15. ACHIEVE "Generate Validation/ast_sem_cli_tests.gasd from Design/cli_design.gasd"
    16. ACHIEVE "Generate Validation/backward_compatibility_tests.gasd from Design/backward_compatibility_design.gasd"
    17. ACHIEVE "Generate Validation/builtin_types_tests.gasd from Design/builtin_types_design.gasd"
    18. ACHIEVE "Generate Validation/global_invariants_tests.gasd from Design/global_invariants_design.gasd"
    19. ACHIEVE "Generate Validation/cross_file_test_matrix_validation.gasd from Design/cross_file_test_matrix.gasd"
    20. ENSURE "Validation specs cover all constraints and type definitions present in Semantic AST Design files including AC-X-SEMAST IDs"

// ===================================================================
// PHASE 8 — Semantic AST Testing (Output: Impl/tests/ folder)
// Generate all Semantic AST acceptance and regression tests.
// CRITICAL: NO existing tests may be modified. (US-SEMAST-017)
// ===================================================================

FLOW phase8_semantic_ast_tests():
    /// Requirement: Consult ONLY Requirements/ver-1.2/GASD Semantic AST.md, Requirements/ver-1.2/Built-in-types-support.md, Requirements/ver-1.3/Cross-File Semantic AST Validation.md and Design/ folders.
    /// Do NOT modify any existing test files. (US-SEMAST-020)
    1. ACHIEVE "Review Requirements/ver-1.2/GASD Semantic AST.md, Requirements/ver-1.2/Built-in-types-support.md, Requirements/ver-1.3/Cross-File Semantic AST Validation.md and Semantic AST Design/ files for testing scope"

    // --- Backward Compatibility Gate (MUST run first) ---
    2. ENSURE "All existing tests in Impl/tests/ pass unmodified before any new test generation" @trace #AC-SEMAST-017-05, #AC-SEMAST-017-06

    // --- Acceptance Tests (Fully driven by Phase 6 Validation Specs) ---
    3. ACHIEVE "Generate Impl/tests/acceptance/test_semast_model.py from Validation/semantic_ast_model_tests.gasd" @trace #AT-SEMAST-001-01 through #AT-SEMAST-001-11, #AT-X-SEMAST-001-01 through #AT-X-SEMAST-001-03
    4. ACHIEVE "Generate Impl/tests/acceptance/test_semast_symbol_resolution.py from Validation/symbol_resolution_tests.gasd" @trace #AT-SEMAST-002-01 through #AT-SEMAST-002-08, #AT-X-SEMAST-003-01 through #AT-X-SEMAST-003-03
    5. ACHIEVE "Generate Impl/tests/acceptance/test_semast_type_binding.py from Validation/type_contract_binding_tests.gasd" @trace #AT-SEMAST-003-01 through #AT-SEMAST-003-08, #AT-X-SEMAST-004-01 through #AT-X-SEMAST-004-02, #AT-X-SEMAST-007-01
    6. ACHIEVE "Generate Impl/tests/acceptance/test_semast_annotations.py from Validation/annotation_handling_tests.gasd" @trace #AT-SEMAST-004-01 through #AT-SEMAST-004-06
    7. ACHIEVE "Generate Impl/tests/acceptance/test_semast_architecture.py from Validation/architecture_deps_tests.gasd" @trace #AT-SEMAST-005-01 through #AT-SEMAST-005-08
    8. ACHIEVE "Generate Impl/tests/acceptance/test_semast_flow.py from Validation/flow_semantic_analysis_tests.gasd" @trace #AT-SEMAST-006-01 through #AT-SEMAST-006-14, #AT-X-SEMAST-006-01 through #AT-X-SEMAST-006-02
    9. ACHIEVE "Generate Impl/tests/acceptance/test_semast_strategy.py from Validation/strategy_resolution_tests.gasd" @trace #AT-SEMAST-007-01 through #AT-SEMAST-007-09
    10. ACHIEVE "Generate Impl/tests/acceptance/test_semast_decision.py from Validation/decision_resolution_tests.gasd" @trace #AT-SEMAST-008-01 through #AT-SEMAST-008-09
    11. ACHIEVE "Generate Impl/tests/acceptance/test_semast_namespace.py from Validation/namespace_import_tests.gasd" @trace #AT-SEMAST-009-01 through #AT-SEMAST-009-05, #AT-X-SEMAST-002-01 through #AT-X-SEMAST-002-03
    12. ACHIEVE "Generate Impl/tests/acceptance/test_semast_hashing.py from Validation/semantic_hashing_tests.gasd" @trace #AT-SEMAST-010-01 through #AT-SEMAST-010-06
    13. ACHIEVE "Generate Impl/tests/acceptance/test_semast_cicd.py from Validation/semantic_hashing_tests.gasd" @trace #AT-SEMAST-011-01 through #AT-SEMAST-011-03
    14. ACHIEVE "Generate Impl/tests/acceptance/test_semast_errors.py from Validation/semantic_error_reporting_design.gasd" @trace #AT-SEMAST-012-01 through #AT-SEMAST-012-03
    15. ACHIEVE "Generate Impl/tests/acceptance/test_semast_directives.py from Validation/context_directive_tests.gasd" @trace #AT-SEMAST-013-01 through #AT-SEMAST-013-06
    16. ACHIEVE "Generate Impl/tests/acceptance/test_semast_human_in_loop.py from Validation/human_in_loop_tests.gasd" @trace #AT-SEMAST-014-01 through #AT-SEMAST-014-06
    17. ACHIEVE "Generate Impl/tests/acceptance/test_semast_resources.py from Validation/resource_block_tests.gasd" @trace #AT-SEMAST-015-01 through #AT-SEMAST-015-03
    18. ACHIEVE "Generate Impl/tests/acceptance/test_semast_cli.py from Validation/ast_sem_cli_tests.gasd" @trace #AT-SEMAST-016-01 through #AT-SEMAST-016-07, #AT-X-SEMAST-010-01 through #AT-X-SEMAST-010-02
    19. ACHIEVE "Generate Impl/tests/acceptance/test_semast_backward_compat.py from Validation/backward_compatibility_tests.gasd" @trace #AT-SEMAST-017-01 through #AT-SEMAST-017-06
    20. ACHIEVE "Generate Impl/tests/acceptance/test_semast_output_reuse.py from Validation/ast_sem_cli_tests.gasd" @trace #AT-SEMAST-018-01 through #AT-SEMAST-018-06
    21. ACHIEVE "Generate Impl/tests/acceptance/test_semast_global_invariants.py from Validation/global_invariants_tests.gasd" @trace #AT-X-SEMAST-009-01 through #AT-X-SEMAST-009-03
    22. ACHIEVE "Generate Impl/tests/acceptance/test_semast_cross_file_matrix.py from Validation/cross_file_test_matrix_validation.gasd" @trace #AT-X-SEMAST-012-01 through #AT-X-SEMAST-012-03
    23. ENSURE "100% of Acceptance Tests and Trace IDs defined in Phase 6/7 Validation files are implemented including AC-X-SEMAST coverage"

    // --- Regression Tests (Fully driven by Phase 6 Validation Specs) ---
    22. ACHIEVE "Generate Impl/tests/regression/test_semast_model_regression.py from Validation/semantic_ast_model_tests.gasd" @trace #RT-SEMAST-001-01, #RT-SEMAST-001-02
    23. ACHIEVE "Generate Impl/tests/regression/test_semast_symbol_regression.py from Validation/symbol_resolution_tests.gasd" @trace #RT-SEMAST-002-01, #RT-SEMAST-002-02
