/*
   Validation: Semantic AST — Annotation Handling Tests
   ====================================================
   Verifies annotation inheritance, scoping, and argument validation.
   Based on Design/annotation_handling_design.gasd.
*/

CONTEXT: "Compiler / Language Tooling — Annotation Validation"
TARGET: "TypeScript", "Python3"
TRACE: "US-SEMAST-004"

// ===================================================================
// Acceptance Tests
// ===================================================================

FLOW test_semast_annotation_override():
    @trace #AT-SEMAST-004-01, #AC-SEMAST-004-01
    1. ACHIEVE "Apply @sensitive(level='low') to TYPE, and @sensitive(level='high') to a FIELD"
    2. ENSURE "Field resolution overrides parent annotation value"

FLOW test_semast_annotation_resolution():
    @trace #AT-SEMAST-004-02, #AC-SEMAST-004-02
    1. ACHIEVE "Extract annotation block via AnnotationResolver"
    2. ENSURE "Syntactic text transforms into typed ResolvedAnnotation"

FLOW test_semast_annotation_validation():
    @trace #AT-SEMAST-004-03, #AC-SEMAST-004-03, #AC-SEMAST-004-05
    1. ACHIEVE "Apply @trace with integer argument"
    2. ENSURE "Validation rejects argument mismatch based on annotation schema"

FLOW test_semast_annotation_hierarchy():
    @trace #AT-SEMAST-004-04, #AC-SEMAST-004-04
    1. ACHIEVE "Apply @deprecated to COMPONENT"
    2. ENSURE "get() method identifies @deprecated when analyzing any FLOW inside COMPONENT"

FLOW test_semast_annotation_propagation():
    @trace #AT-SEMAST-004-05, #AC-SEMAST-004-06
    1. ACHIEVE "Resolve FIELD inside @secure TYPE"
    2. ENSURE "FIELD successfully inherits @secure behavior"

// ===================================================================
// Regression Tests
// ===================================================================

FLOW test_semast_annotation_regression_unknown():
    @trace #RT-SEMAST-004-01
    1. ACHIEVE "Apply @unknown_custom_tag"
    2. ENSURE "Gracefully stored as untyped annotation rather than crashing"
