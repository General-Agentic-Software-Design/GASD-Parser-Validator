VERSION 1.1
/*
   Validation: Semantic AST — Context & Directive Tests
   ====================================================
   Verifies global directives and metadata constraints.
   Based on Design/context_directive_design.gasd.
*/

CONTEXT: "Compiler / Language Tooling — Directive Validation"
TARGET: "TypeScript", "Python3"
TRACE: "US-SEMAST-013"

// ===================================================================
// Acceptance Tests
// ===================================================================

FLOW test_semast_directive_resolution():
    @trace #AT-SEMAST-013-01, #AC-SEMAST-013-01, #AC-SEMAST-013-02
    1. ACHIEVE "Parse CONTEXT and TARGET strings"
    2. ENSURE "System metadata accurately reflects directive values"
        OTHERWISE THROW "Validation Failed"

FLOW test_semast_trace_gathering():
    @trace #AT-SEMAST-013-02, #AC-SEMAST-013-03
    1. ACHIEVE "Parse multiple scattered TRACE directives and inline @trace annotations"
    2. ENSURE "System-wide traces list aggregates all values accurately"
        OTHERWISE THROW "Validation Failed"

FLOW test_semast_global_constraint():
    @trace #AT-SEMAST-013-03, #AC-SEMAST-013-05
    1. ACHIEVE "Place CONTEXT inside a nested FLOW block"
    2. ENSURE "Parser rejects non-global directive placement"
        OTHERWISE THROW "Validation Failed"

FLOW test_semast_trace_format():
    @trace #AT-SEMAST-013-04, #AC-SEMAST-013-06
    1. ACHIEVE "Define @trace with invalid characters '!@#'"
    2. ENSURE "Resolver rejects non-alphanumeric/hyphenated sequence"
        OTHERWISE THROW "Validation Failed"

// ===================================================================
// Regression Tests
// ===================================================================

FLOW test_semast_directive_regression_duplicate():
    @trace #RT-SEMAST-013-01
    1. ACHIEVE "Define multiple CONTEXT directives at root level"
    2. ENSURE "Resolver either merges or warns based on semantic policy"
        OTHERWISE THROW "Validation Failed"
