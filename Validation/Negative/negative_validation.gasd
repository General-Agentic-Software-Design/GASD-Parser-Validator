VERSION 1.2
/*
   Validation: Negative Tests (Strict 1.2 Syntax)
   =============================================
   Validates the system's ability to correctly identify and reject 
   invalid inputs and configurations for GASD v2.0.
*/

NAMESPACE: "GASD-Validator.Validation.Negative"
CONTEXT: "Verification of Error Handling and Reject Logic"
TARGET: "GASD Agent"
TRACE: "US-V2-001", "US-PARSER-007"

FLOW validate_negative_scenarios():
    // --- GEP-6 Semantic Errors ---
    
    1. ACHIEVE "Reject: ACHIEVE without POSTCONDITION in 1.2 context":
        POSTCONDITION: result.severity == "ERROR" AND result.code == "LINT-001"
        @trace(#AC-V2-001-02) AS ACHIEVE_NEG_L001_TRACE
    
    2. ACHIEVE "Reject: IMPORT without CONTRACT in 1.2 context":
        POSTCONDITION: result.severity == "ERROR" AND result.code == "LINT-002"
        @trace(#AC-V2-001-02) AS ACHIEVE_NEG_L002_TRACE

    3. ACHIEVE "Reject: Annotation without AS identifier in 1.2 context":
        POSTCONDITION: result.severity == "ERROR" AND result.code == "LINT-011"
        @trace(#AC-V2-001-02) AS ACHIEVE_NEG_L011_TRACE

    // --- CLI Errors ---
    
    4. ACHIEVE "Reject: Usage of legacy --ast flag":
        POSTCONDITION: result.code == "UNKNOWN_ARGUMENT" AND exit_code == 1
        @trace(#AC-PARSER-007-01) AS ACHIEVE_NEG_AST_TRACE
    
    5. ACHIEVE "Reject: Version mismatch between --gasd-ver and VERSION directive":
        POSTCONDITION: result.severity == "ERROR" AND result.code == "LINT-013"
        @trace(#AC-V2-009-02) AS ACHIEVE_NEG_VER_TRACE

    // --- Structural Errors ---
    6. ACHIEVE "Reject: Invalid VERSION directive placement (not at top)":
        POSTCONDITION: result IS SyntaxError
        @trace(#AC-V2-001-01) AS ACHIEVE_NEG_PLACE_TRACE

    7. ENSURE "All critical error conditions are formally identified and rejected"
        OTHERWISE THROW "Negative Validation Failure"

// ===================================================================
// Constraints
// ===================================================================

CONSTRAINT: "Syntactic errors MUST prevent any AST generation or semantic validation" @trace(#AC-V2-001-01) AS CONST_SYNTAX_BLOCK
