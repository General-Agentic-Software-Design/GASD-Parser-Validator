/*
   Design: CLI Interface Design
   ============================
   Defines the user-facing command-line interface for the GASD parser,
   including argument parsing and bulk specification validation.

   Output: Build/Installation/gasd_parser/cli.py
*/

CONTEXT: "Compiler / Language Tooling — CLI Design"
TARGET: "TypeScript", "Python3"
TRACE: "US-PARSER-006"

// ===================================================================
// Decisions
// ===================================================================

DECISION "Input Argument Strategy":
    CHOSEN: "Variadic file/directory paths (nargs='*')"
    RATIONALE: "Users need to validate entire architecture projects at once, rather than passing a single file at a time. This mirrors standard compiler CLI behavior."
    AFFECTS: [GASDCLI]

DECISION "Directory Traversal":
    CHOSEN: "Recursive discovery of .gasd files"
    RATIONALE: "When a directory is provided, the tool should automatically locate all valid specification files within its hierarchy."
    AFFECTS: [GASDCLI]

DECISION "Output Formatting":
    CHOSEN: "Per-file status followed by aggregated summary (unless JSON mode)"
    RATIONALE: "Provides immediate feedback per file, but a high-level summary at the end prevents scrolling fatigue on large codebases."
    AFFECTS: [GASDCLI]

// ===================================================================
// CLI Component Definition
// ===================================================================

COMPONENT GASDCLI @trace #AC-PARSER-006-01:
    PATTERN: "Command-Line Interface"
    DEPENDENCIES: [ParseTreeAPI, ASTGenerator, ValidationPipeline]
    INTERFACE:
        /// Main application entry point handling sys.argv
        main() -> Void
        
// ===================================================================
// Execution Flow
// ===================================================================

FLOW execute_cli_validation(args: List<String>) -> Integer:
    @trace #AC-PARSER-006-02
    1. ACHIEVE "Parse flags (--json, --validate) and positional path arguments"
    2. CREATE target_files: "Empty list of paths"
    3. ACHIEVE "Evaluate each path in args":
        ACHIEVE "Recursively find *.gasd files for directories"
        ACHIEVE "Add direct .gasd files"
        LOG "Error for missing paths"

    4. IF "No files found":
        LOG "No .gasd files found"
        RETURN 1
    
    5. CREATE summary: "Counters for success/failure"
    6. ACHIEVE "Iterate through each file in target_files":
        ACHIEVE "Read file content"
        ACHIEVE "Run ParseTreeAPI"
        IF "Syntax successful":
            ACHIEVE "Run ASTGenerator"
            ACHIEVE "Run ValidationPipeline"
        ACHIEVE "Print file result (OK/FAIL)"
        ACHIEVE "Update summary counters"
        
    7. ACHIEVE "Print final validation summary across all files" @trace #AC-PARSER-006-03
    8. RETURN 1

// ===================================================================
// Constraints
// ===================================================================

CONSTRAINT: "CLI MUST exit with code 1 if ANY parsed file contains errors" @trace #AC-PARSER-006-03
CONSTRAINT: "Directory traversal MUST only process files ending with .gasd extension" @trace #AC-PARSER-006-02
CONSTRAINT: "CLI MUST process all discovered files sequentially and not halt on the first file error" @trace #AC-PARSER-006-03
