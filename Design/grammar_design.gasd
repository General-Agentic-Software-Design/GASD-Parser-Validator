/*
   Design: GASD Grammar — ANTLR4 Grammar Specification
   ====================================================
   Defines the complete ANTLR4 grammar for parsing GASD 1.1.0 files.
   The official, canonical parser and validator for the **General Agentic Software Design (GASD)** specification language (Version **1.1.1**).

   Output: Impl/grammar/gasd.g4
*/

CONTEXT: "Compiler / Language Tooling — Grammar Design"
TARGET: "ANTLR4"
TRACE: "US-PARSER-001"

// ===================================================================
// Terminology Mapping (User Story -> Language Construct)
// ===================================================================
// "System"       => gasd_file (The entire specification file)
// "Capability"   => COMPONENT (Module defining an interface)
// "Agent"        => FLOW (Operational logic executing capabilities)
// "Contract"     => INTERFACE (Component's boundary)
// "Constraint"   => CONSTRAINT / INVARIANT
// "Verification" => FLOW (Specifically validation steps)
// ===================================================================

// ===================================================================
// Decisions
// ===================================================================

DECISION "Lexer Architecture":
    CHOSEN: "Split Lexer + Parser Grammar (GASDLexer.g4 / GASDParser.g4)"
    RATIONALE: "Indentation handling requires custom lexer logic; separating lexer and parser keeps concerns clean."
    ALTERNATIVES: ["Split Lexer + Parser", "Combined Grammar"]
    AFFECTS: [GASDLexer, GASDParser]

DECISION "Indentation Strategy":
    CHOSEN: "Custom Lexer with INDENT/DEDENT Token Emission"
    RATIONALE: "GASD uses Python-style significant whitespace. A custom lexer override tracks indentation depth and emits synthetic INDENT/DEDENT tokens on the token stream."
    ALTERNATIVES: ["Custom Lexer with INDENT/DEDENT", "Whitespace-agnostic grammar", "Brace-based scopes"]
    AFFECTS: [IndentationTokens]

DECISION "Comment Handling":
    CHOSEN: "Lexer-Level Skip with Documentation Channel"
    RATIONALE: "Single-line (//) and block (/* */) comments are skipped. Documentation comments (///) are sent to a hidden channel for downstream doc generation."
    ALTERNATIVES: ["Lexer-Level Skip with Documentation Channel", "C-style skip"]
    AFFECTS: []

// ===================================================================
// Lexer Token Design
// ===================================================================

/// All GASD keywords that the lexer MUST recognize.
/// Keywords are case-sensitive and MUST be UPPERCASE.
TYPE LexerKeywords:
    CONTEXT_KW: "CONTEXT"
    TARGET_KW: "TARGET"
    TRACE_KW: "TRACE"
    NAMESPACE_KW: "NAMESPACE"
    IMPORT_KW: "IMPORT"
    AS_KW: "AS"
    DECISION_KW: "DECISION"
    CHOSEN_KW: "CHOSEN"
    RATIONALE_KW: "RATIONALE"
    ALTERNATIVES_KW: "ALTERNATIVES"
    AFFECTS_KW: "AFFECTS"

    TYPE_KW: "TYPE"
    LIST_KW: "List"
    MAP_KW: "Map"
    ENUM_KW: "Enum"
    OPTIONAL_KW: "Optional"
    COMPONENT_KW: "COMPONENT"
    INTERFACE_KW: "INTERFACE"
    PATTERN_KW: "PATTERN"
    DEPENDENCIES_KW: "DEPENDENCIES"
    FLOW_KW: "FLOW"
    VALIDATE_KW: "VALIDATE"
    ACHIEVE_KW: "ACHIEVE"
    CREATE_KW: "CREATE"
    PERSIST_KW: "PERSIST"
    RETURN_KW: "RETURN"
    LOG_KW: "LOG"
    ENSURE_KW: "ENSURE"
    OTHERWISE_KW: "OTHERWISE"
    THROW_KW: "THROW"
    EXECUTE_KW: "EXECUTE"
    TRANSFORM_KW: "TRANSFORM"
    UPDATE_KW: "UPDATE"
    APPLY_KW: "APPLY"
    ON_ERROR_KW: "ON_ERROR"
    IF_KW: "IF"
    ELSE_KW: "ELSE"
    STRATEGY_KW: "STRATEGY"
    ALGORITHM_KW: "ALGORITHM"
    PRECONDITION_KW: "PRECONDITION"
    COMPLEXITY_KW: "COMPLEXITY"
    INPUT_KW: "INPUT"
    OUTPUT_KW: "OUTPUT"
    SORT_KEY_KW: "SORT_KEY"
    ORDER_KW: "ORDER"
    CONSTRAINT_KW: "CONSTRAINT"
    INVARIANT_KW: "INVARIANT"
    MATCH_KW: "MATCH"
    DEFAULT_KW: "DEFAULT"
    QUESTION_KW: "QUESTION"
    APPROVE_KW: "APPROVE"
    STATUS_KW: "STATUS"
    BY_KW: "BY"
    DATE_KW: "DATE"
    NOTES_KW: "NOTES"
    BLOCKING_KW: "BLOCKING"
    TODO_KW: "TODO"
    REVIEW_KW: "REVIEW"
    IS_KW: "IS"
    NOT_KW: "NOT"
    AND_KW: "AND"
    OR_KW: "OR"
    CONTAINS_KW: "CONTAINS"
    HAS_KW: "HAS"
    VIA_KW: "via"
    TO_KW: "to"
    RESOURCES_KW: "RESOURCES"

/// Lexer symbols and operators.
TYPE LexerSymbols:
    COLON: ":"
    COMMA: ","
    DOT: "."
    ARROW: "->"
    LPAREN: "("
    RPAREN: ")"
    LBRACKET: "["
    RBRACKET: "]"
    LANGLE: "<"
    RANGLE: ">"
    EQUALS: "="
    AT: "@"
    HASH: "#"
    ASTERISK: "*"
    PLUS: "+"
    MINUS: "-"
    SLASH: "/"
    BACKTICK: "`"
    CARET: "^"
    SQUOTE: "'"
    STEP_NUM: "Integer followed by '.'"

/// Lexer literal formats.
TYPE LexerLiterals:
    STRING_LITERAL: "Double-quoted UTF-8 string with escape sequences"
    INTEGER_LITERAL: "Signed 64-bit integer"
    FLOAT_LITERAL: "IEEE 754 double-precision"
    BOOLEAN_LITERAL: "true | false"
    IDENTIFIER: "[#a-zA-Z_][#a-zA-Z0-9_-]*"
    SOFT_ID: "Keywords used as identifiers in non-ambiguous positions"

/// Synthetic indentation tokens emitted by the custom lexer.
TYPE IndentationTokens:
    INDENT: "Emitted when indentation level increases"
    DEDENT: "Emitted when indentation level decreases"
    NEWLINE: "Emitted at end of each logical line"

// ===================================================================
// Parser Rule Design
// ===================================================================

/// Top-level file structure: a GASD file is a sequence of sections.
/// This rule proves a complete ANTLR grammar file exists for GASD.
TYPE GasdFileRule @trace #AC-PARSER-001-01:
    description: "gasd_file ::= { section } EOF"
    name: String
    arguments: List<AnnotationArg> @optional
    sections: List<SectionRule>

/// Each section maps to a top-level construct.
TYPE SectionRule:
    description: "section ::= context_dir | namespace_stmt | import_stmt | decision_blk | type_def | component_def | flow_def | strategy_def | constraint_stmt | invariant_stmt | match_expr | question_stmt | approve_blk | todo_stmt | review_stmt"

/// Context & Directives rules.
TYPE DirectiveRules:
    context_rule: "CONTEXT ':' value (',' value)*"
    target_rule: "TARGET ':' value (',' value)*"
    trace_rule: "TRACE ':' value (',' value)*"
    namespace_rule: "NAMESPACE ':' STRING_LITERAL"
    import_rule: "IMPORT STRING_LITERAL ('AS' IDENTIFIER)?"

/// DECISION block rule.
TYPE DecisionRule:
    syntax: "DECISION STRING_LITERAL annotations? ':' INDENT CHOSEN ':' STRING_LITERAL (RATIONALE ':' STRING_LITERAL)? (ALTERNATIVES ':' list_literal)? (AFFECTS ':' list_literal) DEDENT"

/// TYPE definition rule.
TYPE TypeDefRule:
    syntax: "TYPE IDENTIFIER annotations? ':' INDENT (field_def)+ DEDENT"
    field_syntax: "soft_id ':' type_expr annotations?"
    type_expr: "soft_id | literal_type | 'List' '<' type_expr '>' | 'Map' '<' type_expr ',' type_expr '>' | 'Enum' '(' type_expr (',' type_expr)* ')' | 'Optional' '<' type_expr '>'"
    literal_type: "STRING_LITERAL | INTEGER_LITERAL | FLOAT_LITERAL | BOOLEAN_LITERAL"

/// COMPONENT definition rule.
TYPE ComponentRule:
    syntax: "COMPONENT soft_id annotations? ':' INDENT (PATTERN ':' value)? (DEPENDENCIES ':' list_literal)? (RESOURCES ':' (INDENT bullet_item+ DEDENT | list_literal))? INTERFACE ':' INDENT (method_sig | field_def)+ DEDENT DEDENT"
    method_syntax: "soft_id '(' param_list? ')' '->' type_expr annotations?"

/// FLOW definition rule.
TYPE FlowRule:
    syntax: "FLOW IDENTIFIER '(' param_list? ')' ('->' type_expr)? ':' INDENT (flow_step)+ DEDENT"
    flow_step: "INTEGER '.' (action | control_flow) annotations? | annotations"
    actions: "Permissive sequences of tokens supporting natural language descriptions in ACHIEVE, CREATE, RETURN, LOG, etc. VALIDATE MUST use explicit binding: VALIDATE expr AS TYPE.typePath." @trace #AC-PARSER-008-01, #AC-PARSER-008-03
    control_flow: "ENSURE expr [OTHERWISE action] | MATCH expr | IF expr ... ELSE"

/// STRATEGY definition rule.
TYPE StrategyRule:
    syntax: "STRATEGY IDENTIFIER annotations? ':' INDENT ALGORITHM ':' STRING_LITERAL (PRECONDITION ':' expr)? (COMPLEXITY ':' STRING_LITERAL)? INPUT ':' param_list OUTPUT ':' type_expr DEDENT"

/// CONSTRAINT / INVARIANT rule.
TYPE ConstraintRule:
    syntax: "CONSTRAINT ':' STRING_LITERAL annotations?"
    invariant_syntax: "INVARIANT ':' STRING_LITERAL annotations?"

/// MATCH expression rule.
TYPE MatchRule:
    syntax: "MATCH (expr | soft_id+) ':' INDENT (match_case)+ DEDENT"
    case_syntax: "[CONTAINS] (pattern (OR pattern)* | DEFAULT) (-> | :) (flow_step | action | block)"

/// QUESTION / APPROVE rule.
TYPE HumanInLoopRule:
    question_syntax: "QUESTION ':' STRING_LITERAL INDENT (BLOCKING ':' BOOLEAN)? (CONTEXT ':' expr)? DEDENT"
    approve_syntax: "APPROVE STRING_LITERAL ':' INDENT STATUS ':' (APPROVED | REJECTED) BY ':' STRING_LITERAL DATE ':' STRING_LITERAL (NOTES ':' STRING_LITERAL)? DEDENT"

/// Annotation syntax.
TYPE AnnotationRule:
    syntax: "'@' IDENTIFIER ('(' value (',' value)* ')')?"
    inline_trace: "'@trace' '#' IDENTIFIER (',' '#' IDENTIFIER)*"

// ===================================================================
// Constraints
// ===================================================================

CONSTRAINT: "Grammar MUST compile successfully using ANTLR4 tooling without errors" @trace #AC-PARSER-001-02
CONSTRAINT: "Grammar MUST be unambiguous — zero ANTLR warnings in production" @trace #AC-PARSER-001-05
CONSTRAINT: "All GASD keywords are case-sensitive and MUST be UPPERCASE" @trace #AC-PARSER-001-03
CONSTRAINT: "Grammar MUST reject syntactically invalid files with clear error tokens" @trace #AC-PARSER-001-04
CONSTRAINT: "Grammar MUST support all GASD 1.1.0 constructs including Literal Types and expert natural language patterns" @trace #AC-PARSER-001-03
CONSTRAINT: "Grammar MUST reject VALIDATE statements without explicit AS TYPE binding" @trace #AC-PARSER-008-02
CONSTRAINT: "INLINE_TRACE (@trace) MUST NOT consume colons ':' to prevent swallowing structural delimiters"
