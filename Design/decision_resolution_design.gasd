VERSION 1.1
/*
   Design: Decision Resolution
   ===========================
   Handles DECISION block (§8) resolution, tracking chosen paths,
   rationales, and impact analysis on system components.

   Output: Impl/semantic/decision/
*/

CONTEXT: "Compiler / Language Tooling — DECISION Design"
TARGET: "TypeScript"
TRACE: "US-SEMAST-008", "US-X-SEMAST-008"

// ===================================================================
// Decision Model
// ===================================================================

TYPE ResolvedDecisionNode @trace #AC-SEMAST-008-01, #AC-X-SEMAST-008-01:
    kind: "ResolvedDecision"
    name: String
    chosen: String
    rationale: String
    alternatives: List<String>
    affectedNodes: List<SymbolLink> @trace #AC-X-SEMAST-008-01, #AC-X-SEMAST-008-02
    isGlobal: Boolean @trace #AC-X-SEMAST-008-03

// ===================================================================
// Components
// ===================================================================

COMPONENT DecisionResolver @trace #AC-SEMAST-008-05:
    INTERFACE:
        /// Resolve decision path and trace effects.
        resolve(decision: Decision) -> ResolvedDecisionNode @trace #AC-SEMAST-008-02, #AC-X-SEMAST-008-05
        /// Verify the chosen alternative exists.
        verifyChoice(decision: ResolvedDecisionNode) -> Void @trace #AC-SEMAST-008-03
        /// Generate impact matrix for all decisions across the unit.
        generateImpactMatrix(unit: CompilationUnit) -> Map<String, List<SymbolLink>> @trace #AC-X-SEMAST-008-01
        /// Detect conflicting decisions affecting the same symbol.
        detectConflicts(unit: CompilationUnit) -> Void @trace #AC-X-SEMAST-008-04

// ===================================================================
// Constraints
// ===================================================================

CONSTRAINT: "Decisions MUST cite at least one affected component or node." @trace #AC-SEMAST-008-07
CONSTRAINT: "Rationale MUST be provided for non-trivial decisions (>= 3 alternatives)." @trace #AC-SEMAST-008-08
CONSTRAINT: "Conflicting decisions affecting the same symbol MUST be detected and reported." @trace #AC-X-SEMAST-008-04
CONSTRAINT: "Wildcard impacts (AFFECTS: [*]) MUST be applied to all relevant symbols globally." @trace #AC-X-SEMAST-008-03
