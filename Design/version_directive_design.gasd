VERSION 1.1
/*
   Design: VERSION Directive & Version-Aware Processing
   =====================================================
   Defines the grammar and semantic rules for the VERSION directive
   and version-specific processing logic for GASD 1.2.

   Output: Impl/grammar/ and Impl/semantic/
*/

CONTEXT: "Compiler / Language Tooling — Version Directive Design"
TARGET: "ANTLR4", "Python3"
TRACE: "US-V2-001", "US-V2-009"

// ===================================================================
// Decisions
// ===================================================================

DECISION "Version Default Behavior" @trace #AC-V2-009-03, #AC-V2-009-04:
    CHOSEN: "Missing VERSION implies 1.2 (unless overridden by CLI)"
    RATIONALE: "Per US-V2-009, the default version for GASD Parser-Validator v2.0 is 1.2 for all new and undecorated files."
    ALTERNATIVES: ["Missing VERSION implies 1.1", "Missing VERSION implies 1.2", "Missing VERSION triggers error"]
    AFFECTS: [VersionResolver]

DECISION "VERSION Directive Placement":
    CHOSEN: "VERSION MUST be the first directive"
    RATIONALE: "Per GEP-6 §10.1, VERSION MUST appear before CONTEXT and TARGET to enable early version-aware parsing."
    ALTERNATIVES: ["VERSION first directive", "VERSION anywhere in header"]
    AFFECTS: [VersionDirectiveRule]

// ===================================================================

// ===================================================================

// Grammar Additions
// ===================================================================

/// VERSION directive grammar rule.
/// version_stmt ::= "VERSION" version_number
/// version_number ::= number_literal "." number_literal [ "." number_literal ]
TYPE VersionDirectiveRule @trace #AC-V2-001-01:
    syntax: "VERSION version_number"
    version_number: "number_literal '.' number_literal ('.' number_literal)?"
    placement: "MUST be the first directive in the file"

/// New lexer keywords for GASD 1.2.
TYPE Gasd12LexerKeywords @trace #AC-V2-001-03:
    VERSION_KW: "VERSION"
    CONTRACT_KW: "CONTRACT"
    MODEL_KW: "MODEL"
    ASSUMPTION_KW: "ASSUMPTION"
    POSTCONDITION_KW: "POSTCONDITION"
    TIMEOUT_KW: "TIMEOUT"
    DEPENDS_ON_KW: "DEPENDS_ON"
    STEP_KW: "STEP"
    BEHAVIORS_KW: "BEHAVIORS"
    CASE_KW: "CASE"
    THROWS_KW: "THROWS"
    AFTER_KW: "AFTER"
    IDEMPOTENT_KW: "IDEMPOTENT"
    LOCAL_KW: "LOCAL"
    GLOBAL_KW: "GLOBAL"
    VERIFIES_KW: "VERIFIES"
    ASSUMPTIONS_KW: "ASSUMPTIONS"
    CONSEQUENCE_KW: "CONSEQUENCE"
    FILE_KW: "FILE"

// ===================================================================
// Version Resolver Component
// ===================================================================

/// Resolves the GASD version from the AST and configures version-specific rules.
COMPONENT VersionResolver @trace #AC-V2-001-02, #AC-V2-009-02, #AC-V2-009-03, #AC-V2-009-04:
    PATTERN: "Strategy"
    DEPENDENCIES: []
    INTERFACE:
        resolveVersion(ast: GASDFile, cliVersion: String @optional) -> String
        isVersion12(ast: GASDFile, cliVersion: String @optional) -> Boolean
        validateVersionConsistency(ast: GASDFile, cliVersion: String @optional) -> List<SemanticError>

FLOW resolve_version(ast: GASDFile, cliVersion: String @optional) -> String:
    @trace #AC-V2-001-02, #AC-V2-009-03, #AC-V2-009-04
    1. ACHIEVE "If cliVersion is provided, return it immediately"
    2. ACHIEVE "Check if V-directive exists in AST"
    3. ACHIEVE "If V-directive exists, validate and return value"
    4. RETURN "1.2"

/// When 1.2 constructs appear in a 1.1 file, emit migration warning.
FLOW check_version_compatibility(ast: GASDFile, version: String) -> List<SemanticError>:
    @trace #AC-V2-001-04, #AC-V2-009-11
    1. ACHIEVE "Detect 1.2 constructs: CONTRACT, MODEL, ASSUMPTION, POSTCONDITION, DEPENDS_ON, scoped INVARIANT, AS identifiers"
    2. ACHIEVE "For each 1.2 construct in a 1.1 file, record a warning-level SemanticError"
    3. ACHIEVE "For each missing REQUIRED construct in a 1.2 file, record an error-level SemanticError"
    4. RETURN "List of SemanticErrors"

/// LINT-013: VERSION_MISMATCH check.
FLOW validate_version_consistency(ast: GASDFile, cliVersion: String @optional) -> List<SemanticError>:
    @trace #AC-V2-009-02
    1. IF "cliVersion is provided AND VERSION directive exists in AST":
        IF "cliVersion != VERSION directive value":
            RECORD "LINT-013: VERSION_MISMATCH Error"
    2. RETURN "List of SemanticErrors"

// ===================================================================
// Constraints
// ===================================================================

CONSTRAINT: "VERSION MUST appear as the first directive, before CONTEXT and TARGET" @trace #AC-V2-001-01
CONSTRAINT: "Files without VERSION SHALL be treated as VERSION 1.2 by default" @trace #AC-V2-009-04
CONSTRAINT: "CLI --gasd-ver MUST override internal VERSION directive or missing VERSION" @trace #AC-V2-009-02, #AC-V2-009-03
CONSTRAINT: "Mismatch between --gasd-ver and internal VERSION directive MUST trigger LINT-013" @trace #AC-V2-009-02
CONSTRAINT: "New 1.2 constructs in a 1.1 file SHALL produce a lint warning, not a parse error" @trace #AC-V2-001-04, #AC-V2-009-11
CONSTRAINT: "Analyzers MUST support all GASD versions >= 1.0" @trace #AC-V2-001-03
