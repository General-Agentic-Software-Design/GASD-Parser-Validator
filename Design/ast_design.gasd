/*
   Design: AST — Abstract Syntax Tree Model
   ==========================================
   Defines the AST node hierarchy, metadata, and the visitor-based
   generator that transforms the ANTLR parse tree into a structured AST.

   Output: Impl/ast/
*/

CONTEXT: "Compiler / Language Tooling — AST Design"
TARGET: "TypeScript"
TRACE: "US-PARSER-003", "US-PARSER-007"
IMPORT "semantic_ast_model_design.gasd"

/// Opaque types representing the ANTLR parse tree contexts.
TYPE GasdFileContext: _internal: Boolean
TYPE DecisionContext: _internal: Boolean
TYPE TypeDefContext: _internal: Boolean
TYPE ComponentDefContext: _internal: Boolean
TYPE FlowDefContext: _internal: Boolean
TYPE StrategyDefContext: _internal: Boolean

COMPONENT GASDParser:
    INTERFACE:
        parse() -> Void

COMPONENT GASDVisitor:
    INTERFACE:
        visit() -> Void

COMPONENT GASDLexer:
    INTERFACE:
        tokenize(input: String) -> Void

COMPONENT ASTNodes:
    INTERFACE:
        node() -> Void

// ===================================================================
// Decisions
// ===================================================================

DECISION "AST vs CST":
    CHOSEN: "Separate AST Layer"
    RATIONALE: "The ANTLR parse tree (CST) includes syntactic noise (colons, commas, keywords). A clean AST simplifies downstream analysis and code generation."
    ALTERNATIVES: ["Separate AST Layer", "In-place CST Processing"]
    AFFECTS: [ASTGenerator]

DECISION "AST Generation Method":
    CHOSEN: "ANTLR Visitor-based Transformation"
    RATIONALE: "A visitor walks the CST and constructs typed AST nodes, allowing full control over the output shape."
    ALTERNATIVES: ["ANTLR Visitor-based Transformation", "CST Listener-based Construction"]
    AFFECTS: []

DECISION "AST Node Identity":
    CHOSEN: "Discriminated Union with NodeKind Enum"
    RATIONALE: "Each AST node carries a 'kind' field for easy pattern matching and type narrowing in TypeScript."
    ALTERNATIVES: ["Discriminated Union with NodeKind Enum", "Class-based Polymorphism"]
    AFFECTS: [ASTNodes]

DECISION "AST Serialization Format" @trace #AC-PARSER-007-03:
    CHOSEN: "JSON"
    RATIONALE: "JSON is the industry standard for structured data exchange and is easily consumable by downstream tooling."
    ALTERNATIVES: ["JSON", "XML", "Protobuf"]
    AFFECTS: [ASTExporter]

// ===================================================================
// AST Node Base
// ===================================================================

/// Every AST node contains source location metadata.
TYPE ASTNodeBase @trace #AC-PARSER-003-03:  
    kind: String
    line: Integer
    column: Integer
    endLine: Integer @optional
    endColumn: Integer @optional
    sourceFile: String @optional
    annotations: List<Annotation> @optional

/// An annotation attached to any construct.
TYPE Annotation:
    name: String
    arguments: List<AnnotationArg> @optional

// ===================================================================
// Design Constraints
// ===================================================================

CONSTRAINT: "INLINE_TRACE (@trace) MUST NOT contain a colon ':' to avoid swallowing structural delimiters."

TYPE AnnotationArg:
    key: String @optional
    value: String

// ===================================================================
// AST Node Hierarchy
// ===================================================================

/// Root node of a parsed GASD file. @trace #AC-PARSER-003-01
TYPE GASDFile:
    kind: "GASDFile"
    directives: List<Directive>
    decisions: List<Decision>
    types: List<TypeDefinition>
    components: List<ComponentDefinition>
    flows: List<FlowDefinition>
    strategies: List<StrategyDefinition>
    constraints: List<ConstraintNode>
    questions: List<QuestionNode> @optional
    approvals: List<ApprovalNode> @optional
    todos: List<TodoNode> @optional
    reviews: List<ReviewNode> @optional

/// Context/Target/Trace/Namespace/Import directives.
TYPE Directive:
    kind: "Directive"
    directiveType: Enum(CONTEXT, TARGET, TRACE, NAMESPACE, IMPORT)
    values: List<String>
    alias: String @optional

/// DECISION block.
TYPE Decision:
    kind: "Decision"
    name: String
    chosen: String
    rationale: String @optional
    alternatives: List<String> @optional
    affects: List<String>

/// TYPE definition with fields.
TYPE TypeDefinition:
    kind: "TypeDefinition"
    name: String
    fields: List<FieldNode>

/// A single field within a TYPE.
TYPE FieldNode:
    kind: "Field"
    name: String
    typeExpr: TypeExpression

/// Type expression (handles generics and enums).
TYPE TypeExpression:
    kind: "TypeExpression"
    baseType: String
    literalValue: String @optional
    genericArgs: List<TypeExpression> @optional
    enumValues: List<TypeExpression> @optional
    isOptional: Boolean @default(false)

/// COMPONENT definition.
TYPE ComponentDefinition:
    kind: "Component"
    name: String
    pattern: String @optional
    dependencies: List<String> @optional
    resources: List<String> @optional
    methods: List<String> @optional

/// Method signature within INTERFACE.
TYPE MethodSignature:
    kind: "MethodSignature"
    name: String
    parameters: List<Parameter>
    returnType: TypeExpression

TYPE Parameter:
    name: String
    type: TypeExpression

/// FLOW definition. @trace #AC-PARSER-003-02
TYPE FlowDefinition:
    kind: "Flow"
    name: String
    parameters: List<Parameter>
    returnType: TypeExpression @optional
    steps: List<FlowStepNode>

/// Individual step in a FLOW.
TYPE FlowStepNode:
    kind: "FlowStep"
    action: Enum(VALIDATE, ACHIEVE, CREATE, PERSIST, RETURN, LOG, EXECUTE, TRANSFORM, ENSURE, MATCH, IF, ELSE, APPLY, UPDATE, ON_ERROR, OTHERWISE, THROW)
    target: String
    asBinding: String @optional @trace #AC-PARSER-008-04
    typePath: String @optional @trace #AC-PARSER-008-04
    errorHandler: String @optional
    subSteps: List<FlowStepNode> @optional

/// STRATEGY definition.
TYPE StrategyDefinition:
    kind: "Strategy"
    name: String
    algorithm: String
    precondition: String @optional
    complexity: String @optional
    inputs: List<Parameter>
    output: TypeExpression

/// CONSTRAINT / INVARIANT node.
TYPE ConstraintNode:
    kind: Enum(Constraint, Invariant)
    text: String

/// QUESTION node.
TYPE QuestionNode:
    kind: "Question"
    text: String
    blocking: Boolean @default(false)
    context: String @optional

/// APPROVE node.
TYPE ApprovalNode:
    kind: "Approval"
    target: String
    status: Enum(APPROVED, REJECTED)
    by: String
    date: String
    notes: String @optional

/// TODO node.
TYPE TodoNode:
    kind: "Todo"
    text: String

/// REVIEW node.
TYPE ReviewNode:
    kind: "Review"
    text: String

// ===================================================================
COMPONENT ReferenceResolutionPass:
    PATTERN: "Analysis"
    INTERFACE:
        resolve(ast: GASDFile) -> Void
COMPONENT SemanticPipeline:
    PATTERN: "Pipeline"
    INTERFACE:
        run(fileNodes: List<ProjectFileNode>) -> SemanticSystem

// ===================================================================

/// Transforms the ANTLR parse tree into a typed AST.
COMPONENT ASTGenerator:
    PATTERN: "Visitor"
    DEPENDENCIES: [GASDParser, GASDVisitor]
    INTERFACE:
        /// Walk the parse tree and produce a GASDFile AST.
        generate(parseTree: GasdFileContext) -> GASDFile
        /// Visit each rule context and return the corresponding AST node.
        visitDecision(ctx: DecisionContext) -> Decision
        visitTypeDef(ctx: TypeDefContext) -> TypeDefinition
        visitComponentDef(ctx: ComponentDefContext) -> ComponentDefinition
        visitFlowDef(ctx: FlowDefContext) -> FlowDefinition
        visitStrategyDef(ctx: StrategyDefContext) -> StrategyDefinition

/// Component responsible for serializing the AST to JSON.
COMPONENT ASTExporter @trace #US-PARSER-007:
    PATTERN: "Serializer"
    DEPENDENCIES: [ASTNodes]
    INTERFACE:
        /// Convert a GASDFile AST into a JSON string.
        toJSON(ast: GASDFile, prettyPrint: Boolean) -> String @trace #AC-PARSER-007-03, #AC-PARSER-007-08

// ===================================================================
// Constraints
// ===================================================================

CONSTRAINT: "AST MUST be deterministic: same input always produces identical AST" @trace #AC-PARSER-003-04
CONSTRAINT: "AST MUST enforce parent-child hierarchy (e.g. Fields under Types, Methods under Components)" @trace #AC-PARSER-003-02
CONSTRAINT: "Every AST node MUST include source location metadata (line, column)" @trace #AC-PARSER-003-03, #AC-PARSER-007-10
CONSTRAINT: "AST node classes MUST represent all GASD constructs" @trace #AC-PARSER-003-01, #AC-PARSER-007-07
