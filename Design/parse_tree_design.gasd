/*
   Design: Parse Tree — Structure & API
   =====================================
   Defines how the ANTLR-generated parse tree maps GASD constructs
   to tree nodes, preserving declaration order, and exposing a public API.

   Output: Impl/parser/
*/

CONTEXT: "Compiler / Language Tooling — Parse Tree Design"
TARGET: "ANTLR4", "TypeScript"
TRACE: "US-PARSER-002"

// ===================================================================
// Decisions
// ===================================================================

DECISION "Parse Tree Representation":
    CHOSEN: "ANTLR4 Native Parse Tree (ParserRuleContext)"
    RATIONALE: "ANTLR4 automatically generates a concrete syntax tree (CST); we use built-in visitor/listener patterns to traverse it."
    ALTERNATIVES: ["ANTLR4 Native Parse Tree", "Custom Interface-based Tree"]
    AFFECTS: [ParseTreeBuilder, ParseTreeAPI]

DECISION "Tree Traversal Pattern":
    CHOSEN: "Visitor Pattern"
    RATIONALE: "Visitor allows returning values from each rule, which is essential for AST construction in Phase 2. Listeners are fire-and-forget."
    ALTERNATIVES: ["Visitor Pattern", "Listener Pattern"]
    AFFECTS: [GASDVisitor]

// ===================================================================
// Parse Tree Node Mapping
// ===================================================================

/// Every GASD construct MUST map to exactly one parse tree node type.
/// The node name matches the parser rule name from the grammar.
/// The structured parse tree is the direct output of the ANTLR parser.
TYPE ParseTreeNodeMap @trace #AC-PARSER-002-01:
    gasd_file: "Root node — contains all top-level sections" @trace #AT-PARSER-002-01
    context_dir: "CONTEXT, TARGET, TRACE directives"
    namespace_stmt: "NAMESPACE declaration"
    import_stmt: "IMPORT declaration"
    decision_blk: "DECISION block with CHOSEN, RATIONALE, AFFECTS"
    type_def: "TYPE definition with fields" @trace #AC-PARSER-002-02
    field_def: "Individual field within a TYPE"
    component_def: "COMPONENT with INTERFACE"
    method_sig: "Method signature within INTERFACE"
    flow_def: "FLOW definition with steps"
    flow_step: "Individual numbered step in a FLOW"
    action: "Permissive token sequences for ACHIEVE, CREATE, LOG, etc."
    control_flow: "ENSURE | MATCH | IF/ELSE control structures"
    strategy_def: "STRATEGY definition"
    constraint_stmt: "CONSTRAINT or INVARIANT declaration"
    match_expr: "MATCH expression with cases"
    match_case: "Individual case within MATCH"
    question_stmt: "QUESTION block"
    approve_blk: "APPROVE block"
    annotations: "Annotation list (@trace, @async, etc.)"
    type_expr: "Type expression (identifier, List<T>, Map<K,V>, Enum, Optional)"

// ===================================================================
// Order Preservation
// ===================================================================

/// Parse tree MUST preserve the declaration order of all constructs.
/// This is critical for deterministic code generation.
TYPE OrderPreservation @trace #AC-PARSER-002-03:
    rule: "Child nodes MUST appear in the same order as their source declarations"
    sections: "Top-level sections maintain file order"
    fields: "TYPE fields maintain declaration order"
    methods: "INTERFACE methods maintain declaration order"
    steps: "FLOW steps maintain step-number order"
    cases: "MATCH cases maintain declaration order"

// ===================================================================
// Public API Design
// ===================================================================

/// The parser exposes a public API for downstream tooling.
COMPONENT ParseTreeAPI @trace #AC-PARSER-002-04:
    PATTERN: "Facade"
    DEPENDENCIES: [GASDLexer, GASDParser]
    INTERFACE:
        /// Parse a GASD source string and return the parse tree root.
        parse(source: String) -> GasdFileContext
        /// Parse a GASD file from disk and return the parse tree root.
        parseFile(filePath: String) -> GasdFileContext
        /// Get all syntax errors encountered during parsing.
        getErrors() -> List<ParseError>
        /// Check if parsing succeeded without errors.
        isValid() -> Boolean

/// Error structure returned by the parser.
TYPE ParseError:
    line: Integer
    column: Integer
    message: String
    offendingToken: String @optional

COMPONENT ParseTreeBuilder @trace #AC-PARSER-002-01:
    INTERFACE:
        /// Build a syntactic parse tree from ANTLR context.
        build(ctx: GasdFileContext) -> Void

// ===================================================================
// Constraints
// ===================================================================

CONSTRAINT: "Parse tree MUST contain a node for every GASD construct in the source" @trace #AC-PARSER-002-02
CONSTRAINT: "Tree traversal MUST preserve source declaration order" @trace #AC-PARSER-002-03
CONSTRAINT: "Parser API MUST be accessible as a public module" @trace #AC-PARSER-002-04
